ARK_API_KEY= #7a
MODEL= #doubao-seed-2-0-pro-260215
GRADE_MODEL= #doubao-seed-2-0-lite-260215
FAST_MODEL= #doubao-seed-1-6-flash-250828
BASE_URL= #https://ark.cn-beijing.volces.com/api/v3

# 本地密集向量（langchain_huggingface / sentence-transformers）
EMBEDDING_MODEL= #BAAI/bge-m3
EMBEDDING_DEVICE= #cpu
DENSE_EMBEDDING_DIM= #1024

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL= #jina-reranker-v3
RERANK_BINDING_HOST= #https://api.jina.ai/v1/rerank
RERANK_API_KEY= #jina_

# ===== OCR =====
# 自动降级链：PaddleOCR（免费本地，需 pip install paddleocr）→ 百度 OCR（云端需 API Key）
# 想单独使用百度 OCR 时填好下面两个 key 即可，PaddleOCR 没装会自动跳过
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# BM25 稀疏统计持久化（默认项目根下 data/bm25_state.json）
# BM25_STATE_PATH=

# 语义三层分块：L3 句子层超长时按 token 切分（默认 300）
# CHUNK_LEVEL3_MAX_TOKENS=300
# CHUNK_LEVEL3_TOKEN_OVERLAP=30

# ===== RAGAS 评估（test_ragas_eval.py）=====
# RAGAS_METRICS=full
# RAGAS_EVAL_CSV=data/ragas_eval_gold.csv
# RAGAS_EVAL_MODEL=
# RAGAS_ANSWER_MODEL=
# RAGAS_EVAL_OUTPUT=